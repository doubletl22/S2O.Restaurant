nked-resource-type=3D"page"><strong>5.3. Ph=C3=A2n t=C3=ADch tri=E1=BB=83n =
khai Menu Service</strong></a></p>
<p local-id=3D"10b934f28239">Menu Service =C4=91=C3=B3ng vai tr=C3=B2 trung=
 t=C3=A2m trong vi=E1=BB=87c qu=E1=BA=A3n l=C3=BD th=E1=BB=B1c =C4=91=C6=A1=
n s=E1=BB=91 cho m=E1=BB=97i nh=C3=A0 h=C3=A0ng. D=E1=BB=8Bch v=E1=BB=A5 n=
=C3=A0y cho ph=C3=A9p t=E1=BA=A1o m=E1=BB=9Bi m=C3=B3n =C4=83n, c=E1=BA=ADp=
 nh=E1=BA=ADt gi=C3=A1, ph=C3=A2n lo=E1=BA=A1i danh m=E1=BB=A5c v=C3=A0 =C4=
=91=E1=BB=93ng b=E1=BB=99 hi=E1=BB=83n th=E1=BB=8B cho giao di=E1=BB=87n QR=
 menu.</p>
<p local-id=3D"78b2d13afb43">M=E1=BB=99t API =C4=91i=E1=BB=83n h=C3=ACnh tr=
ong Menu Service:</p>
<p local-id=3D"0dab814dbd69" style=3D"margin-left: 60.0px;">[HttpPost]</p>
<p local-id=3D"3b6e69641ff6" style=3D"margin-left: 60.0px;">public async Ta=
sk&lt;IActionResult&gt; CreateMenuItem(CreateMenuItemDto dto)</p>
<p local-id=3D"e45e5e3825e2" style=3D"margin-left: 60.0px;">{</p>
<p local-id=3D"8fd01e2877fa" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; var tenantId =3D GetTenantId();</p>
<p local-id=3D"684b7e9d8f01" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; var item =3D new MenuItem</p>
<p local-id=3D"57b52cf14d09" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; {</p>
<p local-id=3D"58696f66b9fb" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp; Id =3D Guid.NewGuid(),</p>
<p local-id=3D"26d607b680ed" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp; TenantId =3D tenantId,</p>
<p local-id=3D"d967dca3490a" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp; Name =3D dto.Name,</p>
<p local-id=3D"bdb52e158b90" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp; Price =3D dto.Price,</p>
<p local-id=3D"459038fde1bb" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp; Category =3D dto.Category,</p>
<p local-id=3D"2071cb76461d" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp;&nbsp;&nbsp;&nbsp;&nbsp; IsAvailable =3D true</p>
<p local-id=3D"5a4c9a2421d8" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; };</p>
<p local-id=3D"d73b32cda12a" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; _context.MenuItems.Add(item);</p>
<p local-id=3D"8377b3d53e04" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; await _context.SaveChangesAsync();</p>
<p local-id=3D"f7061999ef82" style=3D"margin-left: 60.0px;">&nbsp;&nbsp;&nb=
sp; return Ok(item);</p>
<p local-id=3D"9a079ce30240" style=3D"margin-left: 60.0px;">}</p>
<p local-id=3D"0d4a12ef5f82">=C4=90o=E1=BA=A1n x=E1=BB=AD l=C3=BD n=C3=A0y =
th=E1=BB=83 hi=E1=BB=87n:</p>
