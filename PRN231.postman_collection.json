		{
			"name": "FootballPlayer",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"const checkFootballPlayerProperties = (player) => {\r",
							"    pm.expect(player).to.have.property('footballPlayerId');\r",
							"    pm.expect(player).to.have.property('fullName');\r",
							"    pm.expect(player).to.have.property('achievements');\r",
							"    pm.expect(player).to.have.property('birthday');\r",
							"    pm.expect(player).to.have.property('playerExperiences');\r",
							"    pm.expect(player).to.have.property('nomination');\r",
							"    pm.expect(player).to.have.property('footballClubId');\r",
							"    pm.expect(player.footballClub).to.have.property('footballClubId');\r",
							"    pm.expect(player.footballClub).to.have.property('clubName');\r",
							"    pm.expect(player.footballClub).to.have.property('clubShortDescription');\r",
							"    pm.expect(player.footballClub).to.have.property('soccerPracticeField');\r",
							"    pm.expect(player.footballClub).to.have.property('mascos');\r",
							"};\r",
							"\r",
							"pm.test(\"Response has expected properties\", function () {\r",
							"    const responseJson = pm.response.json();\r",
							"    pm.expect(responseJson).to.be.an('array');\r",
							"    responseJson.forEach(player => {\r",
							"        checkFootballPlayerProperties(player);\r",
							"    });\r",
							"});\r",
							"\r",
							"pm.test(\"Check specific player\", function () {\r",
							"    const responseJson = pm.response.json();\r",
							"    const player = responseJson.find(p => p.footballPlayerId === 'PL00961');\r",
							"    pm.expect(player).to.exist;\r",
							"    pm.expect(player.fullName).to.equal(\"Raheem Sterling\");\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
