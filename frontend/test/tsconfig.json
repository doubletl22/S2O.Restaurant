{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "resolveJsonModule": true,
    "types": ["codeceptjs", "node"],
    "baseUrl": "..",
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": [
    "../steps.d.ts",
    "./**/*.ts"
  ]
}
