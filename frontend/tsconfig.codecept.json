{
  "ts-node": {
    "esm": false,
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES2018",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["codeceptjs", "node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "steps.d.ts",
    "steps_file.ts",
    "codecept.conf.ts",
    "test/**/*.ts"
  ]
}
