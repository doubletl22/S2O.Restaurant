    "name": "ITC_34 - Phan tich doanh thu",
    "description": "API test cho chuc nang phan tich doanh thu (time-series) de frontend ve bieu do.\n\nPham vi API chinh:\n- GET /api/v1/orders/owner/revenue-series\n\nLuu y:\n- ITC_34.5 va ITC_34.6 la trang thai UI (loading, thong bao loi than thien). Postman khong kiem chung UI truc tiep, collection nay map thanh API-level checks tuong ung.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Thiet lap chung",
      "item": [
        {
          "name": "CHUNG - Tao owner test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"{{testRestaurantName}}\",\n  \"ownerName\": \"{{testOwnerName}}\",\n  \"email\": \"{{testOwnerEmail}}\",\n  \"password\": \"{{testOwnerPassword}}\",\n  \"address\": \"{{testAddress}}\",\n  \"phoneNumber\": \"{{testPhoneNumber}}\",\n  \"planType\": \"{{testPlanType}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tenants/registration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tenants", "registration"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString();",
                  "pm.environment.set('testSuffix', suffix);",
                  "pm.environment.set('testRestaurantName', `ITC34 Restaurant ${suffix}`);",
                  "pm.environment.set('testOwnerName', `ITC34 Owner ${suffix}`);",
                  "pm.environment.set('testOwnerEmail', `itc34_${suffix}@s2o.com`);",
                  "pm.environment.set('testOwnerPassword', pm.environment.get('ownerPassword') || 'Owner@123');",
                  "pm.environment.set('testAddress', '123 ITC34 Street');",
                  "pm.environment.set('testPhoneNumber', '0909444555');",
                  "pm.environment.set('testPlanType', 'Free');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register tenant 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Register success true', function () { pm.expect(json.isSuccess).to.eql(true); });",
                  "pm.environment.set('testTenantId', json.value);"
                ]
              }
            }
          ]
        },
