    {
      "name": "ITC_34.1 + ITC_34.2 + ITC_34.4 - Time-series data",
      "item": [
        {
          "name": "ITC_34.1 - Owner xem phan tich voi du lieu hop le",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/owner/revenue-series?allTime=false&from={{today}}&to={{today}}&branchId={{ownerBranchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "owner", "revenue-series"],
              "query": [
                { "key": "allTime", "value": "false" },
                { "key": "from", "value": "{{today}}" },
                { "key": "to", "value": "{{today}}" },
                { "key": "branchId", "value": "{{ownerBranchId}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const today = new Date().toISOString().slice(0,10);",
                  "pm.environment.set('today', today);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const arr = pm.response.json();",
                  "pm.test('Body la mang', function () { pm.expect(Array.isArray(arr)).to.eql(true); });",
                  "pm.test('Format time-series hop le', function () {",
                  "  arr.forEach(function (item) {",
                  "    const dateValue = item.date || item.Date;",
                  "    const revenueValue = item.revenue || item.Revenue;",
                  "    pm.expect(dateValue).to.not.eql(undefined);",
                  "    pm.expect(Number(revenueValue)).to.not.eql(NaN);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "ITC_34.2 - Owner xem phan tich khi khong co du lieu",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/owner/revenue-series?allTime=false&from={{futureDate}}&to={{futureDate}}&branchId={{ownerBranchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "owner", "revenue-series"],
              "query": [
                { "key": "allTime", "value": "false" },
                { "key": "from", "value": "{{futureDate}}" },
                { "key": "to", "value": "{{futureDate}}" },
                { "key": "branchId", "value": "{{ownerBranchId}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = new Date();",
                  "d.setFullYear(d.getFullYear() + 2);",
                  "pm.environment.set('futureDate', d.toISOString().slice(0,10));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const arr = pm.response.json();",
                  "pm.test('Khong du lieu thi tra mang rong hoac doanh thu = 0', function () {",
                  "  pm.expect(Array.isArray(arr)).to.eql(true);",
                  "  if (arr.length > 0) {",
                  "    const sum = arr.reduce((s, x) => s + Number(x.revenue || x.Revenue || 0), 0);",
                  "    pm.expect(sum).to.eql(0);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "ITC_34.4 - Khoang thoi gian nho nhat hop le (1 ngay)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/owner/revenue-series?allTime=false&from={{today}}&to={{today}}&branchId={{ownerBranchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "orders", "owner", "revenue-series"],
              "query": [
                { "key": "allTime", "value": "false" },
                { "key": "from", "value": "{{today}}" },
                { "key": "to", "value": "{{today}}" },
                { "key": "branchId", "value": "{{ownerBranchId}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 voi from=to', function () { pm.response.to.have.status(200); });",
                  "const arr = pm.response.json();",
                  "pm.test('Body la mang time-series', function () { pm.expect(Array.isArray(arr)).to.eql(true); });"
                ]
              }
            }
          ]
        }
      ]
    },
